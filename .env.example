# ─── GoHighLevel ───────────────────────────────────────────────
GHL_CLIENT_ID=your_ghl_client_id_here
GHL_CLIENT_SECRET=your_ghl_client_secret_here
REDIRECT_URI=https://your-app.vercel.app/oauth/callback

# ─── Authorize.net ─────────────────────────────────────────────
# Get these from: https://developer.authorize.net
# Use sandbox credentials for testing, live for production
AUTHNET_API_LOGIN=your_api_login_id
AUTHNET_TRANSACTION_KEY=your_transaction_key

# AUTHNET_ENV options: "sandbox" or "production"
AUTHNET_ENV=sandbox

# ─── Security ──────────────────────────────────────────────────
# A random secret used to verify GHL webhook signatures
GHL_WEBHOOK_SECRET=make_up_a_long_random_string_here

# ─── Token Storage (Upstash Redis - free tier) ─────────────────
# Sign up at https://upstash.com for a free Redis instance
# Used to store GHL OAuth tokens per location
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token
